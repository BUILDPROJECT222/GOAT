# Copy to `.env`. `.env` is gitignored.

# === SERVER (backend) — read by server/, NOT exposed to the browser ===
# Helius API key (free, https://helius.dev). Empty -> simulated feed.
VITE_HELIUS_API_KEY=
# Postgres persistence (optional). On Railway this is injected automatically.
# Empty -> in-memory state only (still shared + refresh-proof).
DATABASE_URL=

# === Contract addresses (server uses for polling; client for token cards) ===
# IMPORTANT: Solana addresses are CASE-SENSITIVE — copy exactly from Solscan/DexScreener.
VITE_ANSEM_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump
VITE_PUMPFUN_MINT=4U4U8oXwDyVXGeTffMXds4NAgBgLFwq3wNvTCRTSpump

# === Project info (Info button / X link / CA chip) ===
VITE_APP_NAME=ANSEM vs TJR
VITE_APP_X=
VITE_APP_TOKEN_CA=
VITE_APP_TOKEN_SYMBOL=
