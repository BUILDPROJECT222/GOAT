# Salin file ini jadi `.env` lalu isi nilainya. `.env` tidak ikut ter-commit.
# API key Helius GRATIS dari https://helius.dev (Dashboard -> API Keys, tanpa SOL).
# Kosongkan untuk mode demo (feed simulasi).
VITE_HELIUS_API_KEY=

# Override contract address tiap tim. PENTING: alamat Solana CASE-SENSITIVE,
# salin persis dari Solscan/DexScreener (jangan di-lowercase).
VITE_ANSEM_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump
VITE_PUMPFUN_MINT=4U4U8oXwDyVXGeTffMXds4NAgBgLFwq3wNvTCRTSpump

# Your project info (Info button / X link / CA chip).
VITE_APP_NAME=ANSEM vs TJR
VITE_APP_X=
VITE_APP_TOKEN_CA=
VITE_APP_TOKEN_SYMBOL=
